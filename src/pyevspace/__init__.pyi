from typing import Optional, SupportsFloat, final, overload, Self
from collections.abc import Iterator, Iterable
from numbers import Real
from typing_extensions import disjoint_base

__all__ = (
    'Vector',
    'vector_dot',
    'vector_cross',
    'vector_angle',
    'vector_exclude',
    'vector_proj',
    'Matrix',
    'EulerAngles',
    'RotationOrder',
    'compute_rotation_matrix',
    'rotate_from',
    'rotate_to',
    'rotate_between',
    'ReferenceFrame',
    'X_AXIS',
    'Y_AXIS',
    'Z_AXIS',
    'XYZ',
    'XZY',
    'YXZ',
    'YZX',
    'ZXY',
    'ZYX',
    'XYX',
    'XZX',
    'YXY',
    'YZY',
    'ZXZ',
    'ZYZ',
)

@disjoint_base
class Vector:
    def __new__(cls) -> Self: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, x: SupportsFloat, y: SupportsFloat, z: SupportsFloat)\
        -> None: ...
    @overload
    def __init__(self, iterable: Iterable[SupportsFloat]) -> None: ...

    def __str__(self) -> str: ...
    def __repr__(self) -> str: ...

    def __len__(self) -> int: ...
    def __getitem__(self, _index: int) -> float: ...
    def __setitem__(self, _index: int, value: SupportsFloat) -> None: ...
    def __buffer__(self, flags: int) -> memoryview: ...

    def __neg__(self) -> Vector: ...
    def __add__(self, rhs: Vector) -> Vector: ...
    def __iadd__(self, rhs: Vector) -> Vector: ...
    def __sub__(self, rhs: Vector) -> Vector: ...
    def __isub__(self, rhs: Vector) -> Vector: ...
    def __mul__(self, rhs: SupportsFloat) -> Vector: ...
    def __imul__(self, rhs: SupportsFloat) -> Vector: ...
    def __rmul__(self, rhs: SupportsFloat) -> Vector: ...
    def __truediv__(self, rhs: SupportsFloat) -> Vector: ...
    def __itruediv__(self, rhs: SupportsFloat) -> Vector: ...
    def __matmul__(self, matrix: Matrix) -> Vector: ...
    def __imatmul__(self, matrix: Matrix) -> Vector: ...

    def __eq__(self, rhs: object) -> bool: ...
    def __ne__(self, rhs: object) -> bool: ...

    def __reduce__(self) -> tuple[Vector, tuple[float, float, float]]: ...

    def magnitude(self) -> float: ...
    def magnitude_squared(self) -> float: ...
    def normalize(self) -> None: ...
    def norm(self) -> Vector: ...
    def compare_to_ulp(self, rhs: Vector, max_ulps: int) -> bool: ...
    def compare_to_tol(self, rhs: Vector, rel_tol: float = 1e-9,
                       abs_tol: float = 1e-15) -> bool: ...

    E1: Vector
    E2: Vector
    E3: Vector


@disjoint_base
class Matrix:
    
    def __new__(cls) -> Self: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, row1: Iterable[SupportsFloat]) -> None: ...

    def __str__(self) -> str: ...
    def __repr__(self) -> str: ...

    @overload
    def __getitem__(self, row_index: int) -> memoryview: ...
    @overload
    def __getitem__(self, key: tuple[int, int]) -> float: ...
    @overload
    def __getitem__(self, key: tuple[int, slice]) -> memoryview: ...
    @overload
    def __getitem__(self, key: tuple[slice, int]) -> memoryview: ...
    @overload
    def __getitem__(self, key: tuple[slice, slice]) -> memoryview: ...
    def __buffer__(self, flags: int) -> memoryview: ...

    def __neg__(self) -> Matrix: ...
    def __add__(self, rhs: Matrix) -> Matrix: ...
    def __iadd__(self, rhs: Matrix) -> Matrix: ...
    def __sub__(self, rhs: Matrix) -> Matrix: ...
    def __isub__(self, rhs: Matrix) -> Matrix: ...
    def __imul__(self, rhs: SupportsFloat) -> Matrix: ...
    def __rmul__(self, rhs: SupportsFloat) -> Matrix: ...
    def __truediv__(self, rhs: SupportsFloat) -> Matrix: ...
    def __itruediv__(self, rhs: SupportsFloat) -> Matrix: ...
    @overload
    def __matmul__(self, rhs: Vector) -> Vector: ...
    @overload
    def __matmul__(self, rhs: Matrix) -> Matrix: ...
    def __imatmul__(self, rhs: Matrix) -> Matrix: ...   # type: ignore[misc]

    def __eq__(self, rhs: object) -> bool: ...
    def __ne__(self, rhs: object) -> bool: ...

    def __reduce__(self) -> tuple[Matrix, tuple[tuple[float, ...], ...]]: ...
    
    def transpose(self) -> None: ...
    def transpose_inplace(self) -> Matrix: ...
    def determinate(self) -> float: ...
    def inverse(self) -> Matrix: ...
    def compare_to_ulp(self, rhs: Matrix, max_ulps: int) -> bool: ...
    def compare_to_tol(self, rhs: Matrix, rel_tol: float = 1e-9,
                       abs_tol: float = 1e-15) -> bool: ...

    IDENTITY: Matrix


@disjoint_base
class EulerAngles:
    
    def __new__(cls) -> Self: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, alpha: SupportsFloat, beta: SupportsFloat,
                 gamma: SupportsFloat) -> None: ...

    def __str__(self) -> str: ...
    def __repr__(self) -> str: ...

    def __getitem__(self, index_: int) -> float: ...
    def __setitem__(self, index_: int, value: SupportsFloat) -> None: ...

    def __reduce__(cls) -> tuple: ...


@disjoint_base
class RotationOrder:

    def __new__(cls, first: int, second: int, third: int) -> Self: ...

    def __getitem__(self, index_: int) -> int: ...
    
    def __reduce__(cls) -> tuple: ...

    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

    def __str__(self) -> str: ...
    def __repr__(self) -> str: ...

    @property
    def first(self) -> int: ...

    @property
    def second(self) -> int: ...

    @property
    def third(self) -> int: ...


X_AXIS: int = 0
Y_AXIS: int = 1
Z_AXIS: int = 2

XYZ: RotationOrder = RotationOrder(X_AXIS, Y_AXIS, Z_AXIS)
XZY: RotationOrder = RotationOrder(X_AXIS, Z_AXIS, Y_AXIS)
YXZ: RotationOrder = RotationOrder(Y_AXIS, X_AXIS, Z_AXIS)
YZX: RotationOrder = RotationOrder(Y_AXIS, Z_AXIS, X_AXIS)
ZXY: RotationOrder = RotationOrder(Z_AXIS, X_AXIS, Y_AXIS)
ZYX: RotationOrder = RotationOrder(Z_AXIS, Y_AXIS, X_AXIS)
XYX: RotationOrder = RotationOrder(X_AXIS, Y_AXIS, X_AXIS)
XZX: RotationOrder = RotationOrder(X_AXIS, Z_AXIS, X_AXIS)
YXY: RotationOrder = RotationOrder(Y_AXIS, X_AXIS, Y_AXIS)
YZY: RotationOrder = RotationOrder(Y_AXIS, Z_AXIS, Y_AXIS)
ZXZ: RotationOrder = RotationOrder(Z_AXIS, X_AXIS, Z_AXIS)
ZYZ: RotationOrder = RotationOrder(Z_AXIS, Y_AXIS, Z_AXIS)


@disjoint_base
class ReferenceFrame:
    def __new__(cls) -> Self: ...
    def __init__(self, order: RotationOrder, angles: EulerAngles, *,
                offset: Optional[Vector] = None, intrinsic: bool = True)\
                -> None: ...
    
    def get_matrix(self) -> Matrix: ...
    def get_angles(self) -> EulerAngles: ...

    @overload
    def set_angles(self, alpha: Optional[SupportsFloat] = None,
                   beta: Optional[SupportsFloat] = None,
                   gamma: Optional[SupportsFloat] = None) -> None: ...
    @overload
    def set_angles(self, angles: EulerAngles) -> None: ...

    @overload
    def rotate_to(self, vector: Vector) -> Vector: ...
    @overload
    def rotate_to(self, frame: ReferenceFrame, vector: Vector) -> Vector: ...

    @overload
    def rotate_from(self, vector: Vector) -> Vector: ...
    @overload
    def rotate_from(self, frame: ReferenceFrame, vector: Vector)\
        -> Vector: ...

    @property
    def offset(self) -> Vector: ...

    @offset.setter
    def offset(self, value: Vector) -> Vector: ...

    @property
    def intrinsic(self) -> bool: ...

    @property
    def order(self) -> RotationOrder: ...


def vector_dot(lhs: Vector, rhs: Vector) -> float: ...
def vector_cross(lhs: Vector, rhs: Vector) -> Vector: ...
def vector_angle(from_: Vector, to: Vector) -> Vector: ...
def vector_exclude(vector: Vector, exclude: Vector) -> Vector: ...
def vector_proj(project: Vector, onto: Vector) -> Vector: ...

@overload
def compute_rotation_matrix(angle: SupportsFloat, axis: int | Vector)\
    -> Vector: ...
@overload
def compute_rotation_matrix(order: RotationOrder, angles: EulerAngles, *,
                            intrinsic: bool = True) -> Vector: ...
@overload
def compute_rotation_matrix(order_from: RotationOrder,
                            angles_from: EulerAngles, order_to: RotationOrder,
                            angles_to: EulerAngles, *,
                            intrinsic_from: bool = True,
                            intrinsic_to: bool = True) -> Vector: ...

@overload
def rotate_from(matrix: Matrix, vector: Vector, *,
                offset: Optional[Vector] = None) -> Vector: ...
@overload
def rotate_from(angle: Real, axis: int | Vector, vector: Vector, *,
                offset: Optional[Vector] = None) -> Vector: ...
@overload
def rotate_from(order: RotationOrder, angles: EulerAngles, vector: Vector, *,
                offset: Optional[Vector] = None, intrinsic: bool = True)\
                -> Vector: ...

@overload
def rotate_to(matrix: Matrix, vector: Vector, *,
              offset: Optional[Vector] = None) -> Vector: ...
@overload
def rotate_to(angle: Real, axis: int | Vector, vector: Vector, *,
              offset: Optional[Vector] = None) -> Vector: ...
@overload
def rotate_to(order: RotationOrder, angles: EulerAngles, vector: Vector, *,
              offset: Optional[Vector] = None, intrinsic: bool = True)\
              -> Vector: ...

def rotate_between(order_from: RotationOrder, angles_from: EulerAngles,
                   order_to: RotationOrder, angles_to: EulerAngles,
                   vector: Vector, *,
                   intrinsic_from: bool = True, intrinsic_to: bool = True,
                   offset_from: Optional[Vector] = None,
                   offset_to: Optional[Vector] = None) -> Vector: ...
